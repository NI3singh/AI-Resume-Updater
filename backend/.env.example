# Local PostgreSQL connection (SQLAlchemy URL, psycopg 3 driver).
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/ai_resume_updater

# Secret used to sign JWT access tokens. Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated browser origins allowed by CORS.
FRONTEND_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# Set true only when serving over HTTPS.
COOKIE_SECURE=false

# Nebius LLM (OpenAI-compatible) — powers the resume "Upload" import feature.
# Get these from your Nebius account. With NEBIUS_API_KEY blank, AI import is
# disabled and the parse/verify endpoints return a clean 503 (manual mode still
# works). NEBIUS_BASE_URL / NEBIUS_MODEL override the defaults in config.py.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1/
NEBIUS_MODEL=moonshotai/Kimi-K2.6

# GitHub integration (Profile page) — reads PUBLIC repos only. Optional: a
# classic/fine-grained token (no scopes needed for public data) just raises the
# rate limit from 60/hr to 5000/hr. Leave blank to use the anonymous limit.
GITHUB_TOKEN=
